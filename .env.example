# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.
# The CLI loads `.env` from the current directory by default, or `--dotenv <path>`.
# A real exported shell variable always overrides the value here.

# OpenAI-compatible reviewer credential
OPENAI_API_KEY=

# Optional: custom OpenAI-compatible base URL (proxy, gateway, or local model server).
# Equivalent to the --reviewer-base-url flag; the flag wins if both are set.
OPENAI_BASE_URL=

# Anthropic reviewer credential
ANTHROPIC_API_KEY=
